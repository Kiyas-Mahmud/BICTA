# Session encryption key — at least 32 random characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD=change-me-to-a-random-32+-char-string

# First admin account, created by `npm run seed`.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-12-chars

# Optional: set to a PostgreSQL URL in production. Unset = local SQLite (.data/bicta.db).
# DATABASE_URL=postgres://user:pass@host:5432/bicta

# Email (participant invites, QR delivery, password resets).
# Get a free key at https://resend.com — without it, emails are printed to the
# server console instead of being sent (fine for local development).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# MAIL_FROM must be a sender your Resend account is allowed to use.
# "onboarding@resend.dev" works for testing without a custom domain.
# MAIL_FROM=BICTA <onboarding@resend.dev>
# Public base URL used inside emails (links back to the site).
# PUBLIC_SITE_URL=https://bicta.onrender.com
