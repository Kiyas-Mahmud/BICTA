# Session encryption key — at least 32 random characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_SESSION_PASSWORD=change-me-to-a-random-32+-char-string

# First admin account, created by `npm run seed`.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-12-chars

# Optional: set to a PostgreSQL URL in production. Unset = local SQLite (.data/bicta.db).
# DATABASE_URL=postgres://user:pass@host:5432/bicta
